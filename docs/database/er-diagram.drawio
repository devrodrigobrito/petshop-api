// ======================
// ENUMS
// ======================

Enum user_role {
  ADMIN
  EMPLOYEE
  CLIENT
}

Enum pet_size {
  SMALL
  MEDIUM
  LARGE
}

Enum appointment_status {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}


// ======================
// USERS
// ======================

Table users {
  id uuid [pk]
  email varchar [unique, not null]
  password_hash varchar [not null]
  role user_role
  is_active boolean [default: true]
  created_at timestamp
  updated_at timestamp
}


// ======================
// CLIENTS
// ======================

Table clients {
  id uuid [pk]
  user_id uuid [unique, not null]
  full_name varchar [not null]
  cpf varchar [unique]
  phone varchar
  created_at timestamp
  updated_at timestamp
}


// ======================
// EMPLOYEES
// ======================

Table employees {
  id uuid [pk]
  user_id uuid [unique, not null]
  full_name varchar [not null]
  phone varchar
  created_at timestamp
  updated_at timestamp
}


// ======================
// PETS
// ======================

Table pets {
  id uuid [pk]
  client_id uuid [not null]
  name varchar [not null]
  species varchar [not null]
  breed varchar
  size pet_size
  birth_date date
  created_at timestamp
  updated_at timestamp
}


// ======================
// SERVICES
// ======================

Table services {
  id uuid [pk]
  name varchar [not null]
  description text
  is_active boolean [default: true]
  created_at timestamp
  updated_at timestamp
}


// ======================
// SERVICE DURATIONS
// ======================

Table service_durations {
  id uuid [pk]
  service_id uuid [not null]
  size pet_size [not null]
  duration_minutes int [not null]
  price_in_cents integer [not null]
  created_at timestamp
  updated_at timestamp

  Indexes {
    (service_id, size) [unique]
  }
}


// ======================
// APPOINTMENTS
// ======================

Table appointments {
  id uuid [pk]
  client_id uuid [not null]
  pet_id uuid [not null]
  employee_id uuid
  status appointment_status [not null, default: 'PENDING']
  start_time timestamp [not null]
  end_time timestamp [not null]
  total_duration int [not null]
  total_price_in_cents integer [not null]
  notes text
  cancelled_at timestamp
  cancelled_by_user_id uuid
  admin_notes text
  created_at timestamp
  updated_at timestamp
}


// ======================
// APPOINTMENT SERVICES (SNAPSHOT)
// ======================

Table appointment_services {
  id uuid [pk]
  appointment_id uuid [not null]
  service_id uuid [not null]
  service_name_snapshot varchar [not null]
  duration_minutes_snapshot int [not null]
  price_in_cents_snapshot integer [not null]
  expected_pet_size_snapshot pet_size [not null]
  actual_pet_size pet_size
  adjustment_notes text
  created_at timestamp
}


// ======================
// RELATIONSHIPS
// ======================

Ref: clients.user_id > users.id
Ref: employees.user_id > users.id

Ref: pets.client_id > clients.id

Ref: service_durations.service_id > services.id

Ref: appointments.client_id > clients.id
Ref: appointments.pet_id > pets.id
Ref: appointments.employee_id > employees.id
Ref: appointments.cancelled_by_user_id > users.id

Ref: appointment_services.appointment_id > appointments.id
Ref: appointment_services.service_id > services.id